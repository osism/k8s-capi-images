#!/bin/bash
# Runs in the chroot at the end of DIB's finalise phase, after the bootloader is
# installed. Removes the build scaffolding so it does not ship in the image.
#
# This has to run in finalise.d (in the chroot), not cleanup.d: cleanup.d runs on
# the build host as the unprivileged build user, where these absolute paths refer
# to the host rather than the image -- there it fails with "rm: cannot remove
# '/root/.ansible': Permission denied". It runs after 50-bootloader so the build
# scaffolding is still in place while grub is installed.

if [ "${DIB_DEBUG_TRACE:-0}" -gt 0 ]; then
    set -x
fi
set -euo pipefail

# Scaffolding from the image-builder run: the throwaway Ansible venv and the
# Ansible/pip caches. policy-rc.d is intentionally NOT removed here -- DIB owns
# it (it is created during the build and deleted by DIB's own
# cleanup.d/40-unblock-daemons, a plain "rm" without -f that fails under set -e
# if the file is already gone), so removing it here breaks DIB's cleanup.
rm -rf /opt/image-builder-venv
rm -rf /root/.ansible /root/.cache/pip

# 40-update-apt-for-bootloader refreshed the apt index for the grub install; drop
# it again so the image ships no package index (DIB's dpkg/99-clean-up-cache only
# runs "apt-get clean" and leaves /var/lib/apt/lists in place).
rm -rf /var/lib/apt/lists/*

# Note: /tmp is deliberately left alone. During DIB's chroot phases it holds
# DIB's own machinery (the in_target.d mount, dib-run-parts' active profile dir),
# so a wipe here breaks the build; the residual build temp is tiny and /tmp is
# cleared on boot anyway.
